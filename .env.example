# Copy to `.env.local` and fill in values. Never commit `.env.local`.

# ---------------------------------------------------------------------------
# Backend HTTP API (axios `apiClient` + TanStack Query)
# Use the base URL only — no trailing slash. Example: https://api.example.com
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=

# ---------------------------------------------------------------------------
# Supabase (browser auth + JWT sent to your API as Bearer token)
# Dashboard → Project Settings → API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Site origin (no trailing slash) — used to build password-reset redirectTo URLs, e.g. http://localhost:3000
NEXT_PUBLIC_APP_URL=

# Example dev: http://localhost:3000/login  |  prod: https://your-domain.com/login
NEXT_PUBLIC_SUPABASE_REDIRECT_URL=
